      "emotion": "silence",
      "colorHSB": [50, 10, 95],
      "weight": 0.6
    },
    {
      "id": 6,
      "cn": "持而盈之，不如其已。",
      "en": "Fill a vessel to the brim, and it will spill over.",
      "emotion": "overflow",
      "colorHSB": [10, 70, 95],
      "weight": 0.7
    },
    {
      "id": 7,
      "cn": "少则得，多则惑。",
      "en": "With little, one gains; with much, one is confused.",
      "emotion": "warning",
      "colorHSB": [330, 40, 90],
      "weight": 0.9
    }
