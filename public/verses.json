    {
      "id": 1,
      "cn": "为者败之，执者失之。",
      "en": "Those who act upon things, ruin them; those who cling to things, lose them.",
      "emotion": "chaos",
      "colorHSB": [15, 80, 95],
      "weight": 1.0
    },
    {
      "id": 2,
      "cn": "无为而无不为。",
      "en": "By non-action, nothing is left undone.",
      "emotion": "calm",
      "colorHSB": [180, 25, 90],
      "weight": 1.0
    },
    {
      "id": 3,
      "cn": "反者道之动。",
      "en": "Reversal is the movement of the Dao.",
      "emotion": "cycle",
      "colorHSB": [210, 40, 95],
      "weight": 0.8
    },
    {
      "id": 4,
      "cn": "上善若水。",
      "en": "The highest goodness is like water.",
      "emotion": "water",
      "colorHSB": [190, 50, 95],
      "weight": 0.8
    },
    {
      "id": 5,
      "cn": "大音希声，大象无形。",
